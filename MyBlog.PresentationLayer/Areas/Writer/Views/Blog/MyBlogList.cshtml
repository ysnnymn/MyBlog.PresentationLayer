@model List<MyBlog.EntitiyLayer.Concrete.Article>
@{
    Layout = "~/Areas/Writer/Views/WriterLayout/Index.cshtml";
}

<div class="main-panel">
    <div class="content-wrapper">
        <div class="page-header">
            <h3 class="page-title">BLog İşlemleri</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#">Bloglar</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Benim Bloglarım</li>
                </ol>
            </nav>
        </div>
        <div class="row">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Blog Listesi</h4>
                        <p class="card-description">
                           Yazmış olduğunuz bloglarla ilgili işlemler aşağıdaki panelden gerçekleştirebilirsiniz.
                        </p>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Başlık</th>
                                        <th>Tarih</th>
                                        <th>Sil</th>
                                        <th>Güncelle</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.ArticleId</td>
                                            <td>@item.Title</td>
                                            <td>@item.CreatedDate</td>
                                            <td>
                                                <label class="badge badge-danger">Sil</label>
                                                <label class="badge badge-success">Güncelle</label>
                                            </td>
                                        </tr>
                                    }
                                    
                                   
                                </tbody>
                            </table>
                            <a href="#" class="btn btn-info">Yeni Blog Girişi</a>
                        </div>
                    </div>
                </div>
            </div>
           
        </div>
    </div>
    
</div>